{
  "manifest_version": 3,
  "name": "Maconomy Holiday Guard",
  "version": "1.0.0",
  "description": "Highlights Swedish public holidays in Maconomy timesheets",
  "content_scripts": [
    {
      "matches": [
        "https://*.deltekfirst.com/*"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/highlight.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Maconomy Holiday Guard"
  }
}
